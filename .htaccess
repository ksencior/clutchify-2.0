<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Jeśli żądany adres to istniejący plik (np. style.css, app.js, api.php), otwórz go normalnie
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    # Jeśli żądany adres to istniejący folder, otwórz go normalnie
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # W każdym innym przypadku (np. /teams, /dashboard) przekieruj ruch po cichu na index.html
    RewriteRule ^ index.html [L]
</IfModule>